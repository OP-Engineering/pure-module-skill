#import "__PREFIX__.h"
#import "../cpp/__PREFIX__Module.hpp"
#import <React/RCTBridge+Private.h>
#import <React/RCTLog.h>
#import <ReactCommon/RCTTurboModule.h>
#import <jsi/jsi.h>

@implementation __PREFIX__

@synthesize bridge = _bridge;

RCT_EXPORT_MODULE()

+ (BOOL)requiresMainQueueSetup {
  return YES;
}

// Blocking-synchronous on purpose: this is the one call that crosses the
// TurboModule boundary. It hands the JSI Runtime + CallInvoker straight to
// C++, which then installs the real API as a global JSI object — see
// cpp/__PREFIX__Module.cpp.
RCT_EXPORT_BLOCKING_SYNCHRONOUS_METHOD(install) {
  RCTCxxBridge *cxxBridge = (RCTCxxBridge *)_bridge;
  if (cxxBridge == nil) {
    return @false;
  }

  auto jsiRuntime = (facebook::jsi::Runtime *)cxxBridge.runtime;
  if (jsiRuntime == nil) {
    return @false;
  }

  auto &runtime = *jsiRuntime;
  auto callInvoker = _bridge.jsCallInvoker;

  NSArray *libraryPaths = NSSearchPathForDirectoriesInDomains(
      NSLibraryDirectory, NSUserDomainMask, true);
  NSString *documentPath = [libraryPaths objectAtIndex:0];

  __NAMESPACE__::install(runtime, callInvoker, [documentPath UTF8String]);
  return @true;
}

- (void)invalidate {
  __NAMESPACE__::invalidate();
}

@end
