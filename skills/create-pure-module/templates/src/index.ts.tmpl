import { NativeModules } from 'react-native';
import Native__PREFIX__ from './Native__PREFIX__';

export interface LabeledItem {
  id: number;
  label: string;
}

export interface ExampleHandle {
  add(a: number, b: number): number;
  computeAsync(value: number): Promise<number>;
  labelItems(labels: string[]): LabeledItem[];
}

export interface __PREFIX__Proxy {
  createExample(): ExampleHandle;
}

declare global {
  // eslint-disable-next-line no-var
  var __GLOBAL_PROXY__: __PREFIX__Proxy | undefined;
}

if (global.__GLOBAL_PROXY__ == null) {
  if (NativeModules.__PREFIX__ == null) {
    throw new Error(
      '__PACKAGE_NAME__: base module not found. Did you run pod install / rebuild the Android app after installing?'
    );
  }

  // Call the synchronous blocking install() function: this hands the JSI
  // Runtime + CallInvoker to cpp/__PREFIX__Module.cpp, which sets
  // `global.__GLOBAL_PROXY__`.
  const installed = Native__PREFIX__.install();
  if (!installed) {
    throw new Error(
      '__PACKAGE_NAME__: failed to install JSI bindings — check the native logs for more detail.'
    );
  }

  if (global.__GLOBAL_PROXY__ == null) {
    throw new Error(
      '__PACKAGE_NAME__: install() reported success but global.__GLOBAL_PROXY__ was not set.'
    );
  }
}

const proxy = global.__GLOBAL_PROXY__;

export function createExample(): ExampleHandle {
  return proxy.createExample();
}
