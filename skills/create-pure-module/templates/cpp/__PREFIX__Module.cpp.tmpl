    return jsi::Object::createFromHostObject(rt, example);
  });

  jsi::Object module = jsi::Object(rt);
  module.setProperty(rt, "createExample", std::move(createExample));

  rt.global().setProperty(rt, "__GLOBAL_PROXY__", std::move(module));

  LOGI("[__PREFIX_LOWER__] installed, base path: %s", base_path);
}

