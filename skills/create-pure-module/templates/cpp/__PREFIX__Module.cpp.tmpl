// React Native calls this on JS context invalidation (reload, CodePush,
// ...). Tell every live HostObject to stop background work, then drop our
// references so they can be garbage collected.
void invalidate() {
  invalidated = true;

  for (const auto &example : examples) {
    example->invalidate();
  }

  examples.clear();
}

